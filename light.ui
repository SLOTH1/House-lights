  <property name="styleSheet">
   <string notr="true">

QWidget{
background-color:#0a0a0a;
color:white;
font-family:Nunito;
font-size:11pt;
}

/* Neon Header */

QLabel{
background:qlineargradient(
x1:0,y1:0,x2:1,y2:0,
stop:0 #00f2ff,
stop:1 #0077ff
);
border-radius:6px;
padding:6px;
font-weight:bold;
}

/* GroupBox Neon */

QGroupBox{
border:2px solid #00eaff;
border-radius:12px;
margin-top:10px;
background:#111;
}

QGroupBox::title{
subcontrol-origin:margin;
left:10px;
padding:0 6px;
color:#00eaff;
font-weight:bold;
}

/* Table Dark */

QTableWidget{
background:#0d0d0d;
gridline-color:#00eaff;
border:none;
}

QHeaderView::section{
background:#00aaff;
color:white;
border:none;
padding:5px;
}

/* Button Base */

QPushButton{
border-radius:10px;
font-weight:bold;
padding:6px;
}

/* ON BUTTON */

QPushButton#btn_on{
background:#00ff88;
color:black;
}

QPushButton#btn_on:hover{
background:#00ffaa;
}

/* RESET BUTTON */

QPushButton#btn_reset{
background:#ffaa00;
color:black;
}

QPushButton#btn_reset:hover{
background:#ffc933;
}

/* OFF BUTTON */

QPushButton#btn_off{
background:#ff3c3c;
color:white;
}

QPushButton#btn_off:hover{
background:#ff5555;
}

</string>
